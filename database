-- Gán bàn cho booking (booking_tables) + cập nhật trạng thái bàn RESERVED/OCCUPIED theo booking status
DO $$
DECLARE
  b_confirmed BIGINT;
  b_hold BIGINT;
  b_checkedin BIGINT;
  t3 BIGINT;
  t4 BIGINT;
  t6 BIGINT;
BEGIN
  SELECT id INTO b_confirmed FROM bookings WHERE status='CONFIRMED' ORDER BY id ASC LIMIT 1;
  SELECT id INTO b_hold FROM bookings WHERE status='HOLD' ORDER BY id ASC LIMIT 1;
  SELECT id INTO b_checkedin FROM bookings WHERE status='CHECKED_IN' ORDER BY id ASC LIMIT 1;

  SELECT id INTO t3 FROM tables WHERE name='Bàn 3' LIMIT 1;
  SELECT id INTO t4 FROM tables WHERE name='Bàn 4' LIMIT 1;
  SELECT id INTO t6 FROM tables WHERE name='Bàn 6' LIMIT 1;

  -- Nếu chưa có booking HOLD/CHECKED_IN thì tạo thêm để demo
  IF b_hold IS NULL THEN
    INSERT INTO bookings (user_id, booking_date, booking_time, guests, status, note, guest_name, guest_phone, hold_expires_at)
    SELECT (SELECT id FROM users WHERE email='customer@luxeat.local' LIMIT 1), CURRENT_DATE, '20:00'::time, 4, 'HOLD',
           'Giữ bàn 15 phút', 'Customer', '0900000003', now() + interval '15 minutes'
    RETURNING id INTO b_hold;
  END IF;

  IF b_checkedin IS NULL THEN
    INSERT INTO bookings (user_id, booking_date, booking_time, guests, status, note, guest_name, guest_phone, hold_expires_at)
    SELECT (SELECT id FROM users WHERE email='customer@luxeat.local' LIMIT 1), CURRENT_DATE, '18:00'::time, 4, 'CHECKED_IN',
           'Đã vào bàn', 'Customer', '0900000003', NULL
    RETURNING id INTO b_checkedin;
  END IF;

  -- Gán bàn cho từng booking (idempotent)
  IF b_confirmed IS NOT NULL AND t3 IS NOT NULL THEN
    IF NOT EXISTS (SELECT 1 FROM booking_tables WHERE booking_id=b_confirmed) THEN
      INSERT INTO booking_tables (booking_id, table_id) VALUES (b_confirmed, t3);
    END IF;
    UPDATE tables SET status='RESERVED' WHERE id=t3 AND status='AVAILABLE';
  END IF;

  IF b_hold IS NOT NULL AND t4 IS NOT NULL THEN
    IF NOT EXISTS (SELECT 1 FROM booking_tables WHERE booking_id=b_hold) THEN
      INSERT INTO booking_tables (booking_id, table_id) VALUES (b_hold, t4);
    END IF;
    UPDATE tables SET status='RESERVED' WHERE id=t4 AND status='AVAILABLE';
  END IF;

  IF b_checkedin IS NOT NULL AND t6 IS NOT NULL THEN
    IF NOT EXISTS (SELECT 1 FROM booking_tables WHERE booking_id=b_checkedin) THEN
      INSERT INTO booking_tables (booking_id, table_id) VALUES (b_checkedin, t6);
    END IF;
    UPDATE tables SET status='OCCUPIED' WHERE id=t6;
  END IF;
END $$;

-- Table session + order + items + payment cho booking CHECKED_IN
DO $$
DECLARE
  b BIGINT;
  t BIGINT;
  sess_id BIGINT;
  ord_id BIGINT;
  food1 BIGINT;
  food2 BIGINT;
  pay_id BIGINT;
BEGIN
  SELECT b2.id INTO b
  FROM bookings b2
  WHERE b2.status='CHECKED_IN'
  ORDER BY b2.id DESC LIMIT 1;

  SELECT bt.table_id INTO t FROM booking_tables bt WHERE bt.booking_id=b LIMIT 1;

  IF b IS NULL OR t IS NULL THEN
    RETURN;
  END IF;

  -- session
  IF NOT EXISTS (SELECT 1 FROM table_sessions WHERE booking_id=b AND status='ACTIVE') THEN
    INSERT INTO table_sessions (booking_id, table_id, qr_token, status)
    VALUES (b, t, 'demo-token-001', 'ACTIVE')
    RETURNING id INTO sess_id;
  ELSE
    SELECT id INTO sess_id FROM table_sessions WHERE booking_id=b AND status='ACTIVE' ORDER BY id DESC LIMIT 1;
  END IF;

  -- order
  IF NOT EXISTS (SELECT 1 FROM orders WHERE table_session_id=sess_id AND status IN ('PENDING','SERVING') ) THEN
    INSERT INTO orders (booking_id, table_session_id, status) VALUES (b, sess_id, 'SERVING')
    RETURNING id INTO ord_id;
  ELSE
    SELECT id INTO ord_id FROM orders WHERE table_session_id=sess_id AND status IN ('PENDING','SERVING') ORDER BY id DESC LIMIT 1;
  END IF;

  -- foods
  SELECT id INTO food1 FROM foods ORDER BY id ASC LIMIT 1;
  SELECT id INTO food2 FROM foods ORDER BY id DESC LIMIT 1;

  -- items
  IF NOT EXISTS (SELECT 1 FROM order_items WHERE order_id=ord_id) THEN
    INSERT INTO order_items (order_id, food_id, quantity, price, kitchen_status)
    VALUES
      (ord_id, food1, 2, 35000, 'ACKNOWLEDGED'),
      (ord_id, food2, 1, 32000, 'PENDING');
  END IF;

  -- payment UNPAID
  IF NOT EXISTS (SELECT 1 FROM payments WHERE order_id=ord_id) THEN
    INSERT INTO payments (order_id, amount, method, status)
    VALUES (ord_id, 102000, 'cash', 'UNPAID')
    RETURNING id INTO pay_id;
  END IF;
END $$;

